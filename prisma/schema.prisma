// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Job {
  id             Int       @id @default(autoincrement())
  title          String
  deadline       String
  majors         String
  slots          Int
  /** 赛道分类：高校院所招聘 | 博士/申博/博后 | 地方编制求职 */
  category       String    @default("")
  sourceUrl      String?
  organization   String    @default("")
  provinceCity   String    @default("")
  education      String    @default("")
  ageRequirement String    @default("")
  summary        String    @default("")
  /** 正文 + 附件透视文本，供前台关键字检索 */
  content        String    @default("")
  publishDate    String    @default("")
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
}

/** 爬虫原始数据：列表 + 详情正文，供大模型提炼 */
model RawJob {
  id          Int       @id @default(autoincrement())
  title       String
  link        String    @unique
  publishedAt String    @default("")
  content     String?
  /** 赛道分类（Dify 提炼或人工审核）：高校院所招聘 | 博士/申博/博后 | 地方编制求职 */
  category    String    @default("")
  status      String    @default("PENDING")
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

/** 高校爬虫健康巡逻战报 */
model SchoolStatus {
  id           String   @id
  schoolName   String   @unique
  lastRunTime  DateTime
  status       String
  successCount Int      @default(0)
  errorMsg     String?
}

/** 用户画像：专业/学历/年龄等，供岗位匹配与高亮（userId 预留，待接入 User 表） */
model UserProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  major         String
  degree        String
  age           Int
  isPartyMember Boolean  @default(false)
  originPlace   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/** 来源管理系统，为全国扩展做准备 */
model Source {
  id              String    @id @default(cuid())
  name            String // 来源名称，例如 "湖南省人社厅"
  province        String // 省份，例如 "湖南"
  city            String? // 城市，可空
  type            String // 类型：人社厅 | 高校 | 组织部 | 其他
  url             String // 列表页或首页 URL
  priority        Int       @default(5) // 优先级 1-10，越高越优先抓取
  updateFrequency String    @default("daily") // daily | weekly
  lastCrawled     DateTime?
  status          String    @default("active") // active | inactive | error
  parserConfig    Json? // 解析规则配置，JSON 格式，留给后续扩展
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  jobs JobPosting[]

  @@map("sources")
}

/** 结构化岗位（全国扩展 + 智能匹配） */
model JobPosting {
  id          String    @id @default(cuid())
  sourceId    String
  source      Source    @relation(fields: [sourceId], references: [id])
  title       String
  province    String
  publishDate DateTime?
  deadline    DateTime?
  /** 结构化要求：{ ageLimit, politicalStatus, majorRequirements: [], notes: "", ... } */
  requirements Json
  rawText      String? // 原始文本，供 AI 和溯源使用
  sourceUrl    String // 官网原始链接
  matchStatus  String? // PERFECT | CONFLICT | NORMAL （后续使用）
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("job_postings")
}
